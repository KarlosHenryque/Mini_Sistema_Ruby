<% flash_data = {} %>

<% if flash[:notice] %>
  <% flash_data[:notice] = [flash[:notice]] %> 
<% end %>

<% if flash[:alert] %>
  <% flash_data[:alert] = [flash[:alert]] %>
<% end %>

<% if defined?(@user) && @user.errors.any? %>
  <% flash_data[:alert] = @user.errors.full_messages %> 
<% end %>

<%= content_tag :script, id: 'flash-data', type: 'application/json' do %>
  <%= flash_data.to_json.html_safe %>
<% end %>
